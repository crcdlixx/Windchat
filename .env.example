# Database
POSTGRES_DB=windchat
POSTGRES_USER=windchat
POSTGRES_PASSWORD=change_me_strong_password

# JWT
JWT_SECRET=change_me_jwt_secret_at_least_64_chars_long_random_string_here
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_64_chars_long_random_string

# Storage: "local", "minio", or "s3".
# Use "local" unless you also start the MinIO profile or provide external S3.
STORAGE_TYPE=local

# MinIO (used when STORAGE_TYPE=minio)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password

# S3/MinIO connection (used by backend)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_minio_password
S3_BUCKET=windchat-files
S3_REGION=us-east-1

# Admin
ADMIN_SECRET=change_me_admin_secret

# Message retention (hours, max 24)
MAX_MESSAGE_TTL_HOURS=24
DEFAULT_MESSAGE_TTL_SECONDS=3600

# Cloudflare Turnstile (optional, leave blank to disable)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# CORS (use your public origin in production, for example https://chat.example.com)
CORS_ORIGIN=*

# Production HTTPS deployment
# DOMAIN=chat.example.com
# ACME_EMAIL=admin@example.com
# CERTBOT_EXTRA_ARGS=--staging

# SMTP email (optional, required for email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Frontend URLs (for nginx proxy)
VITE_API_URL=/api
VITE_WS_URL=/ws

# Node environment
NODE_ENV=production
